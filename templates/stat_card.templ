package templates

templ StatCard(value, label string) {
	<div style="display:flex; flex-direction:column; align-items:center; justify-content:center; gap:4px; border-radius:12px; background-color:#F7F8FA; padding:15.5px 0; flex:1;">
		<span style="font-family:Inter,sans-serif; font-size:20px; font-weight:700; color:#1A1A1A;">{ value }</span>
		<span style="font-family:Inter,sans-serif; font-size:11px; color:#888888;">{ label }</span>
	</div>
}
